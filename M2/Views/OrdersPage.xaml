<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="M2.Views.OrdersPage">

    <CollectionView
        ItemsSource="{Binding Orders}"
        x:Name="OrdersCollection">

        <CollectionView.ItemTemplate>

            <DataTemplate>

                <Frame Margin="5">

                    <Grid ColumnDefinitions="*,Auto">

                        <VerticalStackLayout>

                            <Label
                                Text="{Binding Article}"
                                FontAttributes="Bold"/>

                            <Label
                                Text="{Binding StatusName}"/>

                            <Label
                                Text="{Binding PickupLocation}"/>

                        </VerticalStackLayout>

                        <VerticalStackLayout
                            Grid.Column="1">

                            <Label
                                Text="{Binding OrderDate}"/>

                            <Label
                                Text="{Binding DeliveryDate}"/>

                        </VerticalStackLayout>

                    </Grid>

                </Frame>

            </DataTemplate>

        </CollectionView.ItemTemplate>

    </CollectionView>

</ContentPage>